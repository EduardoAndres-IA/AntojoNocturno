# Plantilla de variables de entorno. Copia este archivo como ".env.local"
# y rellena los valores reales. NUNCA subas .env.local a GitHub (ya está ignorado).

# --- Supabase ---
# Panel de Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Mercado Pago (modo de prueba) ---
MP_ACCESS_TOKEN=

# --- WhatsApp del negocio (formato internacional sin + ni espacios, ej 56912345678) ---
WHATSAPP_NUMERO=
